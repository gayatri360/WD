<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TechFront 2024 | The Future of Innovation</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"><style>
body {
    background-color: #0a0a0c;
    color: #e0e0e0;
}
header {
    background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1518779578993-ec3579fee39f');
    background-size: cover;
    padding: 100px 20px;
    text-align: center;
}
h1 { color: #00f2ff; }
.card { background: #16161a; border: none; }
</style></head><body><nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="#">TechFront 2024</a>
  </div>
</nav><header>
  <h1>TECHFRONT 2024</h1>
  <p>Converging Horizons in AI and Quantum Computing</p>
</header><div class="container my-5"><h2 class="mb-3">Watch the Promo</h2>
<div class="ratio ratio-16x9 mb-5">
  <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" allowfullscreen></iframe>
</div><h2 class="mb-4">Featured Speakers</h2>
<div class="row g-4 mb-5">  <div class="col-md-4">
    <div class="card text-center p-3">
      <img src="https://randomuser.me/api/portraits/men/32.jpg" class="rounded-circle mx-auto" width="120">
      <h5 class="mt-3">Dr. Aris Thorne</h5>
      <p>Lead Researcher, Quantum Lab</p>
    </div>
  </div>  <div class="col-md-4">
    <div class="card text-center p-3">
      <img src="https://randomuser.me/api/portraits/women/44.jpg" class="rounded-circle mx-auto" width="120">
      <h5 class="mt-3">Sarah Jenkins</h5>
      <p>CTO, NeuralBridge AI</p>
    </div>
  </div>  <div class="col-md-4">
    <div class="card text-center p-3">
      <img src="https://randomuser.me/api/portraits/men/65.jpg" class="rounded-circle mx-auto" width="120">
      <h5 class="mt-3">Marcus Vane</h5>
      <p>Futurist & Author</p>
    </div>
  </div></div><h2 class="mb-3">Conference Schedule</h2>
<table class="table table-dark table-striped mb-5">
  <thead>
    <tr>
      <th>Time</th>
      <th>Session</th>
      <th>Speaker</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>09:00 AM</td>
      <td>Opening Keynote: The AI Decade</td>
      <td>Sarah Jenkins</td>
    </tr>
    <tr>
      <td>11:30 AM</td>
      <td>Quantum Cryptography Workshop</td>
      <td>Dr. Aris Thorne</td>
    </tr>
    <tr>
      <td>02:00 PM</td>
      <td>Ethical Frameworks in Tech</td>
      <td>Marcus Vane</td>
    </tr>
  </tbody>
</table><h2 class="mb-3">Register Your Spot</h2>
<form class="bg-dark p-4 rounded">  <div class="mb-3">
    <label class="form-label">Full Name</label>
    <input type="text" class="form-control" placeholder="Enter your name" required>
  </div>  <div class="mb-3">
    <label class="form-label">Ticket Tier</label>
    <select class="form-select">
      <option>Early Bird ($199)</option>
      <option>Standard ($399)</option>
      <option>VIP Access ($899)</option>
    </select>
  </div><label class="form-label">Ticket Availability</label>

  <div class="progress mb-3">
    <div class="progress-bar" style="width:85%">85% Sold Out</div>
  </div><button type="submit" class="btn btn-primary">Complete Registration</button>

</form></div><footer class="text-center p-4 text-secondary">
  &copy; 2024 TechFront Conference. All rights reserved.
</footer><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script></body>
</html>